{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @betterme/api exec prisma generate"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @betterme/api exec prisma migrate deploy",
    "startCommand": "pnpm --filter @betterme/api start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
